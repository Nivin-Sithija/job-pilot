# Copy to .env.local for development, or set as real secrets in your hosting platform/CI
# for production. Never commit a file with real values filled in. See
# context/code-standards.md's Environment Variables table for what consumes each one.

NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=

GEMINI_API_KEY=

# App host, not the ingestion-only NEXT_PUBLIC_POSTHOG_HOST — e.g. https://us.posthog.com
POSTHOG_API_HOST=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
